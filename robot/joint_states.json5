// Measured proprioceptive state of one joint group (an arm, a gripper, a hand,
// a mobile base's wheels). Robot-agnostic and self-describing: the joint count
// is producer-defined and equal to positions.len(). There is no id or names
// field; a joint group's identity is its producer and the joint order is the
// producer's own.
{
  peppy_schema: "contract/v1",
  manifest: {
    name: "joint_states",
    tag: "v1"
  },
  interfaces: {
    topics: [
      {
        name: "joint_states",
        qos_profile: "sensor_data",
        message_format: {
          // When this sample was measured, on the producer's peppy-synchronized
          // clock (sim time under a simulated clock), so samples from different
          // producers and hosts are directly comparable.
          stamp: "time",
          // Measured positions, one per joint in this group (radians for
          // revolute joints, metres for prismatic, or a unitless fraction for
          // normalized actuators such as a gripper opening).
          positions: {
            $type: "array",
            $items: "f64",
          },
          // Measured velocities, aligned with `positions`. May be empty when
          // the producer has no velocity estimate.
          velocities: {
            $type: "array",
            $items: "f64",
          },
          // Measured effort (torque/force), aligned with `positions`. May be
          // empty when the producer has no effort estimate.
          effort: {
            $type: "array",
            $items: "f64",
          },
        },
      }
    ]
  }
}
