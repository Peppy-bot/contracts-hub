// Commanded (target) positions for one joint group. Robot-agnostic and
// self-describing like joint_states: the joint count is producer-defined, with
// no id or names field and the joint order matching the producer's
// joint_states.
{
  peppy_schema: "contract/v1",
  manifest: {
    name: "joint_commands",
    tag: "v1"
  },
  interfaces: {
    topics: [
      {
        name: "joint_commands",
        qos_profile: "sensor_data",
        message_format: {
          // Target positions, one per joint in this group, in the same order the
          // matching joint_states producer reports.
          positions: {
            $type: "array",
            $items: "f64",
          },
        },
      }
    ]
  }
}
