// The exclusive control conversation between one commander instance and ONE
// openarm gripper, as a pairing: the commander streams opening setpoints and
// the gripper streams its measured aperture back, both directions scoped to
// the pair: no gripper_id demux, no producer lock-in. Pairs are established
// at instance start (`--pair` / launcher `pairings:`) and dissolve
// automatically when either endpoint dies; the survivor's slot goes silent
// until a new peer is paired.
//
// The always-on broadcast `openarm_gripper_states` contract remains the
// observer surface; this pairing is the exclusive command loop.
{
  peppy_schema: "pairing/v1",
  manifest: {
    name: "openarm_gripper_link",
    tag: "v1",
  },
  roles: ["commander", "gripper"],
  topics: [
    {
      emitted_by: "commander",
      name: "gripper_commands",
      // High-frequency stream where only the latest setpoint matters;
      // occasional drops are acceptable.
      qos_profile: "sensor_data",
      message_format: {
        // Desired opening as a fraction of full jaw travel, matching the
        // gripper_states unit: 0 = closed, 1 = fully open.
        opening: "f64"
      }
    },
    {
      emitted_by: "gripper",
      name: "gripper_states",
      // High-frequency stream where only the latest state matters;
      // occasional drops are acceptable.
      qos_profile: "sensor_data",
      message_format: {
        // Measured opening as a fraction of full jaw travel: 0 = closed,
        // 1 = fully open. Not the per-finger joint positions; this is the
        // single aperture value.
        opening: "f64"
      }
    }
  ]
}
